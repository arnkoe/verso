{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Verso",
  "version": "0.2.0",
  "identifier": "app.verso.desktop",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "operator",
        "title": "Verso — Opérateur",
        "url": "operator.html",
        "width": 1280,
        "height": 820,
        "minWidth": 500,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost data: blob:; media-src 'self' asset: http://asset.localhost blob:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost asset: http://asset.localhost https://github.com https://objects.githubusercontent.com",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["$DOCUMENT/Verso/**", "$APPDATA/**", "$APPLOCALDATA/**"]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/arnkoe/verso/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFFQzc4MzQ0MENFNzYyRTUKUldUbFl1Y01SSVBIcmpXdG1QOHAxTm1TNldRc1BJbUppZHU4aGpYdzBUbkh6RkF1S05SQU9tU3AK"
    }
  }
}
