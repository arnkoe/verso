      "verses": [
        {
          "type": "verse",
          "number": 1,
          "text": "Première ligne de la strophe 1.\nDeuxième ligne de la strophe 1.\nUn saut de ligne se note avec \\n dans le texte."
        },
        {
          "type": "chorus",
          "text": "Texte du refrain.\nIl n'a pas besoin de numéro."
        },
