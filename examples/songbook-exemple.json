          "type": "verse",
          "number": 2,
          "text": "Première ligne de la strophe 2.\nDeuxième ligne de la strophe 2."
        },
        {
          "type": "bridge",
          "text": "Texte du pont (facultatif)."
        }
      ]
    },
    {
      "title": "Titre du second chant",
      "author": null,
      "source_number": 2,
      "verses": [
        {
          "type": "verse",
          "number": 1,
          "text": "Un chant peut n'avoir que des strophes,\nsans refrain ni pont."
